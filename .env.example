SECRET_KEY=cambiar-en-produccion
MAX_UPLOAD_MB=800

# AWS (poner AWS_ENABLED=true para activar el pipeline)
AWS_ENABLED=false
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=rekognition-gym-videos
# Notificaciones (opcional): ARN del topic SNS para avisar fin de jobs
SNS_TOPIC_ARN=
# Bucket de salida de Transcribe (opcional; por defecto usa S3_BUCKET)
TRANSCRIBE_OUTPUT_BUCKET=
# Idioma del audio para Transcribe (los videos de demo están en inglés -> en-US)
TRANSCRIBE_LANGUAGE_CODE=en-US
